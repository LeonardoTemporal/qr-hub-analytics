# Root-level .env template
# Copy this file to .env and populate every variable before running docker compose.
# Do NOT commit .env to version control.

# --- PostgreSQL ---
POSTGRES_USER=qrhub
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=qrhub

# --- Backend ---
# Internal URL used by the backend to build redirect targets.
FRONTEND_URL=http://localhost:3000

# --- Frontend ---
# Publicly reachable backend URL. Used by the QR link (printed on physical QR codes).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Google Analytics 4 ---
# Leave empty to disable GA4 tracking.
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
