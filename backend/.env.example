# URL de base de datos PostgreSQL (Docker Compose)
DATABASE_URL=postgresql+asyncpg://qrhub:qrhub_secret@postgres:5432/qrhub

# URL del frontend Next.js (para redirects)
# Desarrollo: http://localhost:3000
# Producción: https://7fitment.com
FRONTEND_URL=http://localhost:3000

# Ruta a la base de datos GeoIP2 (volumen de Docker)
GEOIP_DB_PATH=/app/GeoLite2-City.mmdb
